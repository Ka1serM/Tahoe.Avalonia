<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Avalonia.Themes.Tahoe.Controls"
        xmlns:icons="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia">

    <Style Selector="controls|EditableList">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Template">
            <ControlTemplate TargetType="controls:EditableList">
                <controls:GroupBox Margin="0">
                    <StackPanel Margin="0" Spacing="0">
                        <!-- Header -->
                        <Grid Margin="18 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <icons:SymbolIcon Grid.Column="0"
                                              FontSize="{DynamicResource text-xl}"
                                              Symbol="{TemplateBinding Icon}" />

                            <Grid Grid.Column="2"
                                  RowDefinitions="Auto,Auto"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Title}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1"
                                           Opacity="0.5"
                                           Text="{TemplateBinding Subtitle}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- Extra command button (e.g., "Sync") -->
                                <Button Content="{TemplateBinding ExtraCommandLabel}"
                                        Command="{TemplateBinding ExtraCommand}"
                                        Margin="2 0 0 0"
                                        IsVisible="{TemplateBinding ExtraCommand, Converter={x:Static ObjectConverters.IsNotNull}}" />

                                <!-- Add button -->
                                <Button Classes="iconSquare"
                                        Command="{TemplateBinding AddCommand}"
                                        Margin="2 0 0 0">
                                    <icons:SymbolIcon Symbol="Add" />
                                </Button>

                                <!-- Remove button -->
                                <Button Classes="iconSquare"
                                        Command="{TemplateBinding RemoveCommand}"
                                        CommandParameter="{Binding $parent[controls:EditableList].SelectedItem}"
                                        Margin="2 0 0 0">
                                    <icons:SymbolIcon Symbol="Subtract" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- List content -->
                        <ItemsPresenter />
                    </StackPanel>
                </controls:GroupBox>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Reduce item margins -->
    <Style Selector="controls|EditableList ListBoxItem">
        <Setter Property="Padding" Value="11 4" />
        <Setter Property="Margin" Value="3 0" />
    </Style>

    <!-- Ensure buttons inside EditableList are flat (not lifted) -->
    <Style Selector="controls|EditableList Button:not(.iconSquare):not(.windowControl)">
        <Setter Property="Theme" Value="{StaticResource flatButtonTheme}" />
    </Style>

</Styles>
