<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Avalonia.Themes.Tahoe.Controls">

    <Styles.Resources>
        <ControlTheme x:Key="editableComboBoxTheme" TargetType="controls:EditableComboBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource radius-md}" />
            <Setter Property="Padding" Value="{StaticResource btn-padding}" />
            <Setter Property="Height" Value="{StaticResource size-md}" />
            <Setter Property="MinHeight" Value="{StaticResource size-md}" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="MaxWidth" Value="176" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="MaxDropDownHeight" Value="320" />
            <Setter Property="FontSize" Value="{StaticResource text-base}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
            <Setter Property="IsTextSearchEnabled" Value="True" />
            <Setter Property="IsEditable" Value="True" />
            <Setter Property="Template">
                <ControlTemplate TargetType="controls:EditableComboBox">
                    <Grid RowDefinitions="Auto,Auto">
                        <Border x:Name="ComboBorder"
                                MinHeight="{TemplateBinding MinHeight}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid ColumnDefinitions="*,Auto">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="SelectionBoxPresenter"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      IsHitTestVisible="False"
                                                      IsVisible="False" />
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Classes="embeddedComboEditor"
                                             Background="Transparent"
                                             BorderBrush="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             CornerRadius="0"
                                             MinHeight="0"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                                </Grid>
                                <Border Grid.Column="1"
                                        Padding="10 0"
                                        Background="Transparent"
                                        IsHitTestVisible="False">
                                    <Path Width="8"
                                          Height="6"
                                          Data="M0,0 L4,4 L8,0"
                                          Stroke="{DynamicResource ForegroundLight}"
                                          StrokeThickness="1.5"
                                          StrokeLineCap="Round"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               Grid.Row="1"
                               IsLightDismissEnabled="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                            <Border Margin="0 4 0 0"
                                    MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Background="{DynamicResource Background}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="0"
                                    CornerRadius="{DynamicResource radius-md}"
                                    BoxShadow="{StaticResource shadow-surface-rest}">
                                <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter Margin="4" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Styles.Resources>

    <Style Selector="controls|EditableComboBox">
        <Setter Property="Theme" Value="{StaticResource editableComboBoxTheme}" />
        <Setter Property="CornerRadius" Value="{DynamicResource radius-full}" />
    </Style>
</Styles>
