<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Avalonia.Themes.Tahoe.Controls">

    <Styles.Resources>
        <ControlTheme x:Key="groupBoxTheme" TargetType="controls:GroupBox">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="CornerRadius" Value="{DynamicResource radius-lg}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <ControlTemplate TargetType="controls:GroupBox">
                    <Border x:Name="Chrome"
                            ClipToBounds="True"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter ClipToBounds="True"
                                          Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Styles.Resources>

    <Style Selector="controls|GroupBox">
        <Setter Property="Theme" Value="{StaticResource groupBoxTheme}" />
    </Style>

    <Style Selector="controls|GroupBox.lift">
        <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="controls|GroupBox.lift /template/ Border#Chrome">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-rest}" />
    </Style>
    <Style Selector="controls|GroupBox.clipContent">
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="controls|GroupBox.clipContent /template/ Border#Chrome">
        <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="controls|GroupBox Button:not(.windowControl):not(.overlayGizmo):not(.drawerLift)">
        <Setter Property="Theme" Value="{StaticResource flatButtonTheme}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="controls|GroupBox ToggleButton:not(.overlayGizmo):not(.drawerLift)">
        <Setter Property="Theme" Value="{StaticResource flatToggleButtonTheme}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="controls|GroupBox ComboBox:not(.drawerLift)">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="controls|GroupBox ComboBox:not(.drawerLift) /template/ Border#ComboBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    </Style>
    <Style Selector="controls|GroupBox TextBox:not(.embeddedComboEditor)">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="controls|GroupBox TextBox:not(.embeddedComboEditor) /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    </Style>
    <Style Selector="controls|GroupBox NumericUpDown">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="controls|GroupBox NumericUpDown /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    </Style>
    <Style Selector="controls|GroupBox controls|EditableComboBox /template/ Border#ComboBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    </Style>
    <Style Selector="controls|GroupBox ToggleSwitch /template/ Border#Track">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="controls|GroupBox CheckBox">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</Styles>
