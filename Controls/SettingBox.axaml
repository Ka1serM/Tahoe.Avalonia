<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icons="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
        xmlns:controls="clr-namespace:Avalonia.Themes.Tahoe.Controls">

    <Style Selector="controls|SettingBox">
        <Setter Property="Template">
            <ControlTemplate TargetType="controls:SettingBox">
                <controls:GroupBox Margin="0">
                    <Grid Margin="18 12" Height="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <icons:SymbolIcon Grid.Column="0"
                                          FontSize="{StaticResource text-xl}"
                                          IsVisible="{TemplateBinding ShowIcon}"
                                          Symbol="{TemplateBinding Icon}" />

                        <Grid Grid.Column="2"
                              RowDefinitions="Auto,Auto"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding DisplayName}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1"
                                       Opacity="0.5"
                                       Text="{TemplateBinding Path}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <ContentPresenter Grid.Column="4"
                                          Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Right"
                                          Padding="0"
                                          VerticalAlignment="Center" />
                    </Grid>
                </controls:GroupBox>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|SettingBox.grouped">
        <Setter Property="Template">
            <ControlTemplate TargetType="controls:SettingBox">
                <Grid RowDefinitions="Auto,Auto">
                    <Grid Grid.Row="0" Margin="18 12" Height="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <icons:SymbolIcon Grid.Column="0"
                                          FontSize="{StaticResource text-xl}"
                                          IsVisible="{TemplateBinding ShowIcon}"
                                          Symbol="{TemplateBinding Icon}" />

                        <Grid Grid.Column="2"
                              RowDefinitions="Auto,Auto"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding DisplayName}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1"
                                       Opacity="0.5"
                                       Text="{TemplateBinding Path}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <ContentPresenter Grid.Column="4"
                                          Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Right"
                                          Padding="0"
                                          VerticalAlignment="Center" />
                    </Grid>

                    <Border x:Name="RowDivider"
                            Grid.Row="1"
                            Height="1"
                            Margin="18 0"
                            Background="{DynamicResource Border}" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|SettingBox.grouped.last /template/ Border#RowDivider">
        <Setter Property="IsVisible" Value="False" />
    </Style>
</Styles>
