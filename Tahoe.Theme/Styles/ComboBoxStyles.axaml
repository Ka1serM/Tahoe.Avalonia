<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ComboBox                                      -->
    <Style Selector="ComboBox">
        <Setter Property="Theme" Value="{StaticResource comboBoxTheme}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource radius-full}" />
        <Setter Property="Padding" Value="{StaticResource btn-padding}" />
        <Setter Property="Height" Value="{StaticResource size-md}" />
        <Setter Property="MinHeight" Value="{StaticResource size-md}" />
        <Setter Property="MinWidth" Value="{StaticResource combobox-min-width}" />
        <Setter Property="MaxWidth" Value="{StaticResource combobox-max-width}" />
        <Setter Property="FontSize" Value="{StaticResource text-base-size}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="IsTextSearchEnabled" Value="True" />
        <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="ComboBox:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
        <Setter Property="Background" Value="{DynamicResource BackgroundLight}" />
    </Style>
    <Style Selector="ComboBox.lift /template/ Border#ComboBorder">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-rest}" />
    </Style>
    <Style Selector="ComboBox.lift:pointerover /template/ Border#ComboBorder">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-hover}" />
    </Style>
    <!-- editableCombo — same as base ComboBox but with a visible 1px border -->
    <Style Selector="ComboBox.editableCombo">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="ComboBox.editableCombo:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
        <Setter Property="Background" Value="{DynamicResource BackgroundLight}" />
    </Style>
    <Style Selector="ComboBox.editableCombo.lift /template/ Border#ComboBorder">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-rest}" />
    </Style>
    <Style Selector="ComboBox.editableCombo.lift:pointerover /template/ Border#ComboBorder">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-hover}" />
    </Style>
    <Style Selector="ComboBoxItem">
        <Setter Property="Padding" Value="10 7" />
        <Setter Property="Margin" Value="0 1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ComboBoxItem /template/ Border">
        <Setter Property="CornerRadius" Value="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}}" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource OverlaySoft}" />
    </Style>
    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
    </Style>

</Styles>
