<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ScrollViewer / ScrollBar                      -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="AllowAutoHide" Value="True" />
    </Style>
    <!-- Overlay scrollbars: hidden until the viewer is hovered/focused -->
    <Style Selector="ScrollViewer ScrollBar">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="ScrollViewer ScrollBar:vertical">
        <Setter Property="Width" Value="7" />
        <Setter Property="MinWidth" Value="7" />
        <Setter Property="Margin" Value="0,3" />
    </Style>
    <Style Selector="ScrollViewer ScrollBar:horizontal">
        <Setter Property="Height" Value="7" />
        <Setter Property="MinHeight" Value="7" />
        <Setter Property="Margin" Value="3,0" />
    </Style>
    <Style Selector="ScrollViewer:pointerover ScrollBar, ScrollViewer:focus-within ScrollBar, ScrollBar:pointerover">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource ForegroundLight}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="MinWidth" Value="5" />
        <Setter Property="MinHeight" Value="5" />
    </Style>
    <Style Selector="ScrollBar:pointerover /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource BorderStrong}" />
    </Style>
    <Style Selector="ScrollBar:pressed /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource Border}" />
    </Style>

</Styles>
