<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:notifications="clr-namespace:Avalonia.Controls.Notifications;assembly=Avalonia.Controls">

    <!-- NotificationCard                              -->
    <Style Selector="notifications|NotificationCard">
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource radius-lg}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="MaxWidth" Value="420" />
    </Style>
    <Style Selector="notifications|NotificationCard /template/ Border">
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter Property="BorderThickness" Value="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter Property="CornerRadius" Value="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter Property="BoxShadow" Value="0 1 1 0 #20FFFFFF, 0 16 32 0 #24000000" />
    </Style>
    <Style Selector="notifications|NotificationCard:pointerover /template/ Border">
        <Setter Property="BoxShadow" Value="0 1 1 0 #28FFFFFF, 0 20 36 0 #2A000000" />
    </Style>
    <Style Selector="notifications|NotificationCard TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontFamily" Value="SF Pro Text, Segoe UI Variable, Segoe UI" />
    </Style>
    <Style Selector="notifications|NotificationCard Button">
        <Setter Property="Theme" Value="{StaticResource flatButtonTheme}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="CornerRadius" Value="{StaticResource radius-full}" />
    </Style>
    <Style Selector="notifications|NotificationCard Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource OverlaySoft}" />
    </Style>
    <!-- Notification severity variants — border colour + outline shadow -->
    <Style Selector="notifications|NotificationCard:information">
        <Setter Property="BorderBrush" Value="#603584E4" />
    </Style>
    <Style Selector="notifications|NotificationCard:information /template/ Border">
        <Setter Property="BoxShadow" Value="0 1 1 0 #20FFFFFF, 0 16 32 0 #24000000, 0 0 0 1 #203584E4" />
    </Style>
    <Style Selector="notifications|NotificationCard:success">
        <Setter Property="BorderBrush" Value="#6628C840" />
    </Style>
    <Style Selector="notifications|NotificationCard:success /template/ Border">
        <Setter Property="BoxShadow" Value="0 1 1 0 #20FFFFFF, 0 16 32 0 #24000000, 0 0 0 1 #2028C840" />
    </Style>
    <Style Selector="notifications|NotificationCard:warning">
        <Setter Property="BorderBrush" Value="#66FEBB2E" />
    </Style>
    <Style Selector="notifications|NotificationCard:warning /template/ Border">
        <Setter Property="BoxShadow" Value="0 1 1 0 #20FFFFFF, 0 16 32 0 #24000000, 0 0 0 1 #20FEBB2E" />
    </Style>
    <Style Selector="notifications|NotificationCard:error">
        <Setter Property="BorderBrush" Value="#66FE5F57" />
    </Style>
    <Style Selector="notifications|NotificationCard:error /template/ Border">
        <Setter Property="BoxShadow" Value="0 1 1 0 #20FFFFFF, 0 16 32 0 #24000000, 0 0 0 1 #20FE5F57" />
    </Style>

</Styles>
