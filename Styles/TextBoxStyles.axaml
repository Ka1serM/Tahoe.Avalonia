<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <Thickness x:Key="textbox-padding">10 7</Thickness>
    </Styles.Resources>

    <!-- TextBox                                       -->
    <Style Selector="TextBox">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource radius-full}" />
        <Setter Property="Padding" Value="{StaticResource textbox-padding}" />
        <Setter Property="FontSize" Value="{StaticResource text-base}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Foreground}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Selection}" />
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource Foreground}" />
        <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="TextBox /template/ Border">
        <Setter Property="CornerRadius" Value="{DynamicResource radius-full}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox /template/ ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
        <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
    </Style>
    <Style Selector="TextBox /template/ ScrollViewer ScrollBar">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Width" Value="0" />
        <Setter Property="Height" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="TextBox /template/ TextBlock.watermark">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundLight}" />
    </Style>
    <Style Selector="TextBox:pointerover">
        <Setter Property="Background" Value="{DynamicResource BackgroundLight}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
        <Setter Property="CornerRadius" Value="{DynamicResource radius-full}" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource BackgroundLight}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource radius-full}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
    </Style>
    <Style Selector="TextBox.lift /template/ Border">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-rest}" />
    </Style>
    <Style Selector="TextBox.lift:pointerover /template/ Border">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-hover}" />
    </Style>
    <Style Selector="TextBox.lift:focus /template/ Border">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-surface-hover}" />
    </Style>
    <!-- Embedded editor inside ComboBox — all chrome stripped -->
    <Style Selector="TextBox.embeddedComboEditor, TextBox.embeddedComboEditor:pointerover, TextBox.embeddedComboEditor:focus">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="TextBox.embeddedComboEditor /template/ Border, TextBox.embeddedComboEditor:pointerover /template/ Border, TextBox.embeddedComboEditor:focus /template/ Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

</Styles>
