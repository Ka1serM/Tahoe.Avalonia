<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <!-- Toggle switch sizing (internal) -->
        <x:Double x:Key="toggle-knob-bounds-width">32</x:Double>
        <x:Double x:Key="toggle-knob-width">28</x:Double>
        <x:Double x:Key="toggle-knob-height">16</x:Double>
        <x:Double x:Key="toggle-knob-start-x">0</x:Double>
        <x:Double x:Key="toggle-knob-checked-x">4</x:Double>

        <ControlTheme x:Key="toggleSwitchTheme" TargetType="ToggleSwitch">
            <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Width" Value="{StaticResource size-lg}" />
            <Setter Property="MinWidth" Value="{StaticResource size-lg}" />
            <Setter Property="Height" Value="20" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="KnobTransitions">
                <Transitions>
                    <DoubleTransition Property="Canvas.Left" Duration="0:0:0.18" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate TargetType="ToggleSwitch">
                    <Grid ColumnDefinitions="Auto,8,*"
                          ClipToBounds="False"
                          VerticalAlignment="Center">
                        <Grid Grid.Column="0"
                              Width="{StaticResource size-lg}"
                              Height="20"
                              ClipToBounds="False">
                            <Border x:Name="Track"
                                    TemplatedControl.IsTemplateFocusTarget="True"
                                    Width="{StaticResource size-lg}"
                                    Height="20"
                                    Background="{DynamicResource ForegroundLight}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="0"
                                    CornerRadius="999">
                                <Border.Transitions>
                                    <Transitions>
                                        <BrushTransition Duration="0:0:0.16" Property="Background" />
                                        <BrushTransition Duration="0:0:0.16" Property="BorderBrush" />
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                            <Canvas x:Name="PART_SwitchKnob"
                                    Width="{StaticResource toggle-knob-bounds-width}"
                                    Height="20"
                                    ClipToBounds="False">
                                <Grid x:Name="PART_MovingKnobs"
                                      Canvas.Left="{StaticResource toggle-knob-start-x}"
                                      Width="{StaticResource toggle-knob-bounds-width}"
                                      Height="20">
                                    <Border x:Name="KnobVisual"
                                            Width="{StaticResource toggle-knob-width}"
                                            Height="{StaticResource toggle-knob-height}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="999"
                                            Background="{DynamicResource AccentForeground}"
                                            BorderBrush="#20000000"
                                            BorderThickness="0"
                                            BoxShadow="{StaticResource shadow-toggle-knob}">
                                        <Border.Transitions>
                                            <Transitions>
                                                <BrushTransition Duration="0:0:0.16" Property="Background" Easing="CubicEaseOut" />
                                                <BrushTransition Duration="0:0:0.16" Property="BorderBrush" Easing="CubicEaseOut" />
                                            </Transitions>
                                        </Border.Transitions>
                                    </Border>
                                </Grid>
                            </Canvas>
                        </Grid>
                        <ContentPresenter x:Name="PART_OnContentPresenter"
                                          Grid.Column="2"
                                          Content="{TemplateBinding OnContent}"
                                          ContentTemplate="{TemplateBinding OnContentTemplate}"
                                          VerticalAlignment="Center"
                                          Opacity="0" />
                        <ContentPresenter x:Name="PART_OffContentPresenter"
                                          Grid.Column="2"
                                          Content="{TemplateBinding OffContent}"
                                          ContentTemplate="{TemplateBinding OffContentTemplate}"
                                          VerticalAlignment="Center"
                                          Opacity="0" />
                    </Grid>
                </ControlTemplate>
            </Setter>

            <!-- Unchecked -->
            <Style Selector="^:unchecked /template/ Border#Track">
                <Setter Property="Background" Value="{DynamicResource ForegroundLight}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            </Style>
            <Style Selector="^:unchecked /template/ Grid#PART_MovingKnobs">
                <Setter Property="Canvas.Left" Value="{StaticResource toggle-knob-start-x}" />
            </Style>
            <Style Selector="^:unchecked /template/ Border#KnobVisual">
                <Setter Property="Background" Value="{DynamicResource AccentForeground}" />
                <Setter Property="BorderBrush" Value="#20000000" />
            </Style>
            <Style Selector="^:unchecked /template/ ContentPresenter#PART_OffContentPresenter">
                <Setter Property="Opacity" Value="1" />
            </Style>

            <!-- Checked -->
            <Style Selector="^:checked /template/ Border#Track">
                <Setter Property="Background" Value="{DynamicResource Accent}" />
                <Setter Property="BorderBrush" Value="#22000000" />
            </Style>
            <Style Selector="^:checked /template/ Grid#PART_MovingKnobs">
                <Setter Property="Canvas.Left" Value="{StaticResource toggle-knob-checked-x}" />
            </Style>
            <Style Selector="^:checked /template/ Border#KnobVisual">
                <Setter Property="Background" Value="{DynamicResource AccentForeground}" />
                <Setter Property="BorderBrush" Value="#20000000" />
            </Style>
            <Style Selector="^:checked /template/ ContentPresenter#PART_OnContentPresenter">
                <Setter Property="Opacity" Value="1" />
            </Style>

            <!-- Pointer-over -->
            <Style Selector="^:pointerover /template/ Border#Track">
                <Setter Property="Background" Value="{DynamicResource ForegroundLight}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
            </Style>
            <Style Selector="^:pointerover:checked /template/ Border#Track">
                <Setter Property="Background" Value="{DynamicResource Accent}" />
                <Setter Property="BorderBrush" Value="#30000000" />
            </Style>
            <Style Selector="^:pointerover /template/ Border#KnobVisual">
                <Setter Property="Background" Value="{DynamicResource AccentForeground}" />
                <Setter Property="BorderBrush" Value="#26000000" />
            </Style>

            <!-- Pressed -->
            <Style Selector="^:pressed /template/ Border#Track">
                <Setter Property="Background" Value="{DynamicResource ForegroundLight}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
            </Style>
            <Style Selector="^:pressed:checked /template/ Border#Track">
                <Setter Property="Background" Value="{DynamicResource Accent}" />
                <Setter Property="BorderBrush" Value="#30000000" />
            </Style>
            <Style Selector="^:pressed /template/ Border#KnobVisual">
                <Setter Property="Background" Value="{DynamicResource AccentForeground}" />
                <Setter Property="BorderBrush" Value="#26000000" />
            </Style>

            <!-- Focus -->
            <Style Selector="^:focus-visible /template/ Border#Track">
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                <Setter Property="BoxShadow" Value="0 0 0 3 #26314D66" />
            </Style>

            <!-- Disabled -->
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.55" />
            </Style>
            <Style Selector="^:disabled:checked /template/ Border#Track">
                <Setter Property="Background" Value="{DynamicResource Accent}" />
                <Setter Property="BorderBrush" Value="#22000000" />
            </Style>
            <Style Selector="^:disabled /template/ Border#KnobVisual">
                <Setter Property="Background" Value="{DynamicResource AccentForeground}" />
                <Setter Property="BorderBrush" Value="#20000000" />
            </Style>
        </ControlTheme>
    </Styles.Resources>

    <!-- ToggleSwitch                                  -->
    <Style Selector="ToggleSwitch">
        <Setter Property="Theme" Value="{StaticResource toggleSwitchTheme}" />
        <Setter Property="FontSize" Value="{StaticResource text-base}" />
        <Setter Property="Width" Value="{StaticResource size-lg}" />
        <Setter Property="MinWidth" Value="{StaticResource size-lg}" />
        <Setter Property="Height" Value="20" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Padding" Value="0" />
    </Style>

</Styles>
