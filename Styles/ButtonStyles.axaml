<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <!-- Shared raised-chrome template used by Button -->
        <ControlTheme x:Key="buttonTheme" TargetType="Button">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid x:Name="Root" ClipToBounds="False">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BoxShadow="{StaticResource shadow-control-rest}">
                            <Border.Transitions>
                                <Transitions>
                                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.12" Easing="QuadraticEaseOut" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        <Border x:Name="Highlight"
                                Background="Transparent"
                                BorderBrush="{DynamicResource OverlaySoft}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding CornerRadius}" />
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Chrome">
                <Setter Property="BoxShadow" Value="{StaticResource shadow-control-hover}" />
            </Style>
            <Style Selector="^:pressed /template/ Border#Chrome">
                <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
            </Style>
            <Style Selector="^:pressed /template/ Border#Highlight">
                <Setter Property="Opacity" Value="0.45" />
            </Style>
        </ControlTheme>

        <!-- Flat (no shadow) variant — used inside cards/notifications -->
        <ControlTheme x:Key="flatButtonTheme" TargetType="Button">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="False"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Styles.Resources>

    <!-- Button                                        -->
    <Style Selector="Button">
        <Setter Property="Theme" Value="{StaticResource buttonTheme}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource radius-full}" />
        <Setter Property="Padding" Value="{StaticResource btn-padding}" />
        <Setter Property="Height" Value="{StaticResource size-md}" />
        <Setter Property="MinHeight" Value="{StaticResource size-md}" />
        <Setter Property="FontSize" Value="{StaticResource text-base}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource BackgroundLight}" />
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{DynamicResource BackgroundDark}" />
    </Style>
    <Style Selector="Button.lift:pressed">
        <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
    </Style>
    <Style Selector="Button.lift:pressed:pointerover">
        <Setter Property="Background" Value="{DynamicResource BackgroundLight}" />
    </Style>
    <!-- Square icon button -->
    <Style Selector="Button.iconSquare">
        <Setter Property="Width" Value="{StaticResource size-md}" />
        <Setter Property="Height" Value="{StaticResource size-md}" />
        <Setter Property="MinWidth" Value="{StaticResource size-md}" />
        <Setter Property="MinHeight" Value="{StaticResource size-md}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="999" />
    </Style>
    <!-- Elevated / lifted button (generic) -->
    <Style Selector="Button.lift:not(.iconSquare) /template/ Border#Chrome">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-rest}" />
        <Setter Property="Transitions">
            <Transitions>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.12" Easing="QuadraticEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.lift:not(.iconSquare):pointerover /template/ Border#Chrome">
        <Setter Property="BoxShadow" Value="{StaticResource shadow-card-hover}" />
    </Style>
    <Style Selector="Button.lift:not(.iconSquare):pressed /template/ Border#Chrome">
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    </Style>

</Styles>
